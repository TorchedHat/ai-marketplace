{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent Handoff Request",
  "description": "Schema for agent-to-agent task handoff in torch compile debugging",
  "type": "object",
  "required": ["type", "from_agent", "to_agent", "task", "expected_deliverable"],
  "properties": {
    "type": {
      "const": "handoff_request",
      "description": "Event type identifier"
    },
    "from_agent": {
      "type": "string",
      "enum": ["coordinator-agent", "dynamo-expert-agent", "inductor-expert-agent", "aot-debugger-agent", "bisector-agent"],
      "description": "Agent initiating handoff"
    },
    "to_agent": {
      "type": "string",
      "enum": ["coordinator-agent", "dynamo-expert-agent", "inductor-expert-agent", "aot-debugger-agent", "bisector-agent"],
      "description": "Target agent for task"
    },
    "task": {
      "type": "object",
      "required": ["type", "issue"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "debug_graph_break",
            "debug_compilation_failure",
            "debug_fusion_decision",
            "analyze_kernel_performance",
            "trace_operation_lowering",
            "bisect_failure"
          ]
        },
        "issue": {
          "type": "string",
          "description": "Human-readable issue description"
        },
        "context": {
          "type": "object",
          "properties": {
            "code_snippet": {"type": "string"},
            "log_excerpt": {"type": "string"},
            "debug_dir": {"type": "string"},
            "files": {"type": "array", "items": {"type": "string"}},
            "prior_findings": {"type": "object"}
          }
        }
      }
    },
    "expected_deliverable": {
      "type": "string",
      "enum": ["structured_json", "file_analysis", "routing_decision", "bisection_result"]
    },
    "priority": {
      "type": "string",
      "enum": ["high", "medium", "low"],
      "default": "medium"
    }
  }
}
