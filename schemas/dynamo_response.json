{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Dynamo Debugger Response",
  "description": "Structured response schema for dynamo-debugger-agent",
  "type": "object",
  "required": ["specialist", "version", "task", "confidence", "insight", "files", "guidance"],
  "properties": {
    "specialist": {
      "const": "dynamo-debugger-agent",
      "description": "Agent identifier"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Agent version (semver)"
    },
    "task": {
      "type": "string",
      "description": "Original question or task"
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"],
      "description": "Confidence level in the response"
    },
    "insight": {
      "type": "string",
      "description": "One-sentence key finding"
    },
    "files": {
      "type": "array",
      "items": {"type": "string", "pattern": "^[^:]+:\\d+"},
      "description": "List of file:line references"
    },
    "concepts": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Key concepts involved"
    },
    "guidance": {
      "type": "string",
      "description": "2-3 paragraph explanation of why/how"
    },
    "code": {
      "type": "string",
      "description": "Minimal runnable code example"
    },
    "steps": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Actionable steps with file:line references"
    },
    "dependencies": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Prerequisites needed"
    },
    "pitfalls": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Common mistakes to avoid"
    },
    "skill_references": {
      "type": "array",
      "items": {"type": "string"},
      "description": "References to skill sections"
    },
    "handoff": {
      "type": ["object", "null"],
      "properties": {
        "to_agent": {"type": "string"},
        "reason": {"type": "string"},
        "context": {"type": "object"}
      },
      "description": "Optional handoff to another agent"
    }
  }
}
